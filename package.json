{
  "name": "duri-fe",
  "version": "0.0.0",
  "packageManager": "yarn@4.5.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "duri": "yarn workspace @duri-fe/duri dev",
    "salon": "yarn workspace @duri-fe/salon dev",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@svgr/cli": "^8.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "turbo": "^2.3.0"
  },
  "dependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "axios": "^1.7.7",
    "emotion-reset": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
